# ===== LLM (interchangeable via LiteLLM) =====
# Exemples: anthropic/claude-sonnet-4-6 | openai/gpt-4.1 | gemini/gemini-2.5-pro | deepseek/deepseek-chat
LLM_MODEL=anthropic/claude-sonnet-4-6
LLM_MODEL_HEAVY=anthropic/claude-sonnet-4-6   # rédaction du rapport / synthèses longues
LLM_MODEL_CHEAP=anthropic/claude-haiku-4-5-20251001  # map-reduce sur les gros volumes de reviews
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# ===== Collecte =====
APIFY_TOKEN=
RAPIDAPI_KEY=
SEMRUSH_API_KEY=            # optionnel

# ===== Donnees industrie =====
CENSUS_API_KEY=              # https://api.census.gov/data/key_signup.html
SEC_USER_AGENT=              # EDGAR exige: "Nom Prenom email@domaine.com"
SEC_API_IO_KEY=              # optionnel (fallback tiers)

# ===== Infra =====
REDIS_URL=redis://redis:6379/0
DATA_DIR=/data
API_AUTH_TOKEN=change-me    # token que ton front-end enverra en Authorization: Bearer
